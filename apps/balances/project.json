{
  "name": "balances",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/balances/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/rspack:rspack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "target": "web",
        "outputPath": "dist/apps/balances",
        "main": "apps/balances/src/main.ts",
        "tsConfig": "apps/balances/tsconfig.app.json",
        "rspackConfig": "apps/balances/rspack.config.ts",
        "assets": ["apps/balances/src/favicon.ico", "apps/balances/src/assets"],
        "styles": ["node_modules/bootstrap/dist/css/bootstrap.min.css"],
        "scripts": ["node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"]
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production",
          "optimization": true,
          "sourceMap": false,
          "rspackConfig": "apps/balances/rspack.config.prod.ts"
        }
      }
    },
    "serve": {
      "executor": "@nx/rspack:module-federation-dev-server",
      "options": {
        "buildTarget": "balances:build:development",
        "port": 4202
      },
      "configurations": {
        "development": {},
        "production": {
          "buildTarget": "balances:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "defaultConfiguration": "production",
      "options": {
        "buildTarget": "balances:build",
        "watch": false,
        "port": 4202
      },
      "configurations": {
        "development": {
          "buildTarget": "balances:build:development"
        },
        "production": {
          "buildTarget": "balances:build:production"
        }
      }
    }
  }
}
